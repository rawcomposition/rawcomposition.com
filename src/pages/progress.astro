---
import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import CaretRight from '@/icons/CaretRight.astro';
import { getEbirdImgUrl, getCountryName } from '@/helpers/ebird';
import { SHOW_ENDEMICS } from '@/consts';
import overview from '../../lifelist/overview.json';
import byFamily from '../../lifelist/by-family.json';
import stats from '../../lifelist/reported-stats.json';
import taxonomy from '../../taxonomy.json';
import islandEndemics from '../../island-endemics';

type Species = {
	name: string;
	code: string;
	count: number;
	date: string;
	year: string;
	family: string;
	img: number;
	w: number;
	h: number;
};

const LIFETIME_GOAL = 5000;
const YEARLY_GOAL = 100;
const FAVORITE_FAMILIES = ['Hummingbirds', 'Owls'];

const ebirdUserId = import.meta.env.PUBLIC_EBIRD_USER_ID;

const familyData = byFamily as { family: string; species: Species[] }[];
const allSpecies = familyData.flatMap((it) => it.species);
const photographedCodes = new Set(allSpecies.map((it) => it.code));
const reportedCodes = new Set(stats.speciesCodes);
const taxonomyData = taxonomy as { code: string; name: string; family: string }[];
const speciesNames = new Map(taxonomyData.map((it) => [it.code, it.name]));

// Lifetime quest
const photographedTotal = overview.total;
const lifetimePercent = Math.round((photographedTotal / LIFETIME_GOAL) * 100);
const latestLifer = [...allSpecies].sort((a, b) => a.date.localeCompare(b.date)).pop()!;
const latestLiferDate = new Date(latestLifer.date).toLocaleDateString('en-US', {
	month: 'long',
	day: 'numeric',
	year: 'numeric',
});

// This year
const currentYear = String(new Date().getFullYear());
const yearLifers = stats.yearLifers.find((it) => it.year === currentYear)?.count ?? 0;
const yearPhotographed = allSpecies.filter((it) => it.year === currentYear).length;
const startOfYear = new Date(Number(currentYear), 0, 1).getTime();
const endOfYear = new Date(Number(currentYear) + 1, 0, 1).getTime();
const yearElapsedPercent = Math.round(((Date.now() - startOfYear) / (endOfYear - startOfYear)) * 100);
const yearGoalPercent = Math.min(Math.round((yearLifers / YEARLY_GOAL) * 100), 100);

// Lifers-by-year chart
const chartYears = stats.yearLifers;
const chartMax = Math.max(...chartYears.map((it) => it.count), YEARLY_GOAL);
const yMax = Math.ceil(chartMax / 100) * 100 + 50;
const yTicks = Array.from({ length: Math.floor(yMax / 100) + 1 }, (_, i) => i * 100);
const chart = { width: 860, height: 300, top: 24, right: 14, bottom: 26, left: 38 };
const plotW = chart.width - chart.left - chart.right;
const plotH = chart.height - chart.top - chart.bottom;
const slotW = plotW / chartYears.length;
const barW = Math.min(22, slotW - 8);
const yScale = (value: number) => chart.top + plotH - (value / yMax) * plotH;
const maxYearCount = Math.max(...chartYears.map((it) => it.count));
const brandOrange = '#e2632a';

// Favorite families
const favoriteFamilies = FAVORITE_FAMILIES.map((name) => {
	const species = familyData.find((it) => it.family === name)?.species ?? [];
	const total = taxonomyData.filter((it) => it.family === name).length;
	const recent = [...species].sort((a, b) => b.date.localeCompare(a.date)).slice(0, 3);
	const slug = name.toLowerCase().replaceAll(' ', '-').replaceAll("'", '').replaceAll(',', '');
	return { name, slug, count: species.length, total, recent };
});

// Countries
const flagEmoji = (code: string) =>
	String.fromCodePoint(...[...code.toUpperCase()].map((c) => 0x1f1e6 + c.charCodeAt(0) - 65));
const countries = stats.countries.map(({ code, count }) => ({
	code,
	count,
	name: getCountryName(code),
	flag: flagEmoji(code),
}));
const maxCountryCount = countries[0]?.count ?? 1;

// Island endemics
const endemicIslands = islandEndemics.map((island) => {
	const species = island.species.map((sp) => ({
		...sp,
		name: speciesNames.get(sp.code) ?? sp.code,
		photographed: photographedCodes.has(sp.code),
		seen: reportedCodes.has(sp.code),
	}));
	return {
		name: island.name,
		flag: flagEmoji(island.regionCodes[0]),
		species,
		photographed: species.filter((sp) => sp.photographed).length,
	};
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Goals & Progress | RawComposition.com"
			description={`Tracking my quest to photograph ${LIFETIME_GOAL.toLocaleString()} bird species — ${photographedTotal.toLocaleString()} so far`}
		/>
	</head>
	<body>
		<Header noMargin />
		<div class="bg-neutral-800/90 p-2">
			<div class="mx-auto max-w-[1200px] px-4 text-gray-400 text-xs sm:text-sm">
				<a href="/" class="text-gray-200">Home</a>
				<CaretRight class="mx-1.5" />
				Goals & Progress
			</div>
		</div>

		<div class="relative">
			<img src={getEbirdImgUrl(latestLifer.img, 2400)} alt={latestLifer.name} class="w-full object-cover aspect-[2] sm:aspect-[2.5]" />
			<div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/80 via-black/50 to-transparent pt-24 pb-6">
				<div class="mx-auto max-w-[1200px] px-4 text-white [text-shadow:0_1px_4px_rgba(0,0,0,0.9)]">
					<p class="uppercase text-[0.7rem] font-bold tracking-wider text-gray-200 mb-1">
						Latest addition &middot; Lifer #{photographedTotal.toLocaleString()}
					</p>
					<p class="font-heading text-2xl sm:text-3xl font-bold">{latestLifer.name}</p>
					<p class="text-sm text-gray-200">{latestLiferDate}</p>
				</div>
			</div>
		</div>

		<div class="mx-auto max-w-[1200px] px-4 -mt-0 sm:-mt-0">
			<!-- Lifetime quest -->
			<div class="p-6 sm:p-12 bg-white mb-4">
				<h1 class="font-heading text-neutral-600 text-4xl mb-2">The Quest: 5,000 Species</h1>
				<p class="text-gray-500 mb-10 max-w-2xl">
					My lifelong dream is to photograph <strong>{LIFETIME_GOAL.toLocaleString()}</strong> bird species — about half
					of all the birds on Earth.
				</p>
				<div class="flex items-baseline gap-3 mb-3">
					<span class="font-heading text-5xl sm:text-6xl font-bold text-neutral-700">{photographedTotal.toLocaleString()}</span>
					<span class="text-xl text-gray-400">/ {LIFETIME_GOAL.toLocaleString()} photographed</span>
					<span class="ml-auto font-heading text-2xl font-bold text-orange">{lifetimePercent}%</span>
				</div>
				<div class="relative h-5 rounded-full bg-gray-200 overflow-hidden">
					<div class="absolute inset-y-0 left-0 rounded-full bg-[#f4793d]" style={`width: ${(photographedTotal / LIFETIME_GOAL) * 100}%`}></div>
					{[1000, 2000, 3000, 4000].map((tick) => (
						<div class="absolute inset-y-0 w-0.5 bg-white/70" style={`left: ${(tick / LIFETIME_GOAL) * 100}%`}></div>
					))}
				</div>
				<div class="relative h-5 text-[0.65rem] text-gray-400 mt-1 hidden sm:block">
					{[1000, 2000, 3000, 4000].map((tick) => (
						<span class="absolute -translate-x-1/2" style={`left: ${(tick / LIFETIME_GOAL) * 100}%`}>{tick.toLocaleString()}</span>
					))}
				</div>
				<p class="text-sm text-gray-500 mt-2">
					Plus a few heard-only and seen-only birds: <strong class="text-neutral-600">{stats.total.toLocaleString()}</strong> species reported on
					{' '}<a href="https://ebird.org/profile/NzMwMzI1/world" target="_blank" rel="noopener noreferrer" class="text-orange">eBird</a>.
				</p>
				<a
					href={`/lifelist/${overview.years[0]}`}
					class="inline-block bg-[#f4793d] hover:bg-[#e2632a] text-white font-bold text-sm py-2.5 px-6 mt-6"
				>
					Browse My Life List &rarr;
				</a>
			</div>

			<!-- This year + chart -->
			<div class="flex flex-col lg:flex-row gap-4 mb-4">
				<div class="p-6 sm:p-10 bg-white lg:w-[34%]">
					<h2 class="font-heading text-neutral-600 text-2xl mb-1">{currentYear} Lifers</h2>
					<p class="text-gray-500 text-sm mb-8">Goal: {YEARLY_GOAL} new species every year</p>
					<div class="flex items-baseline gap-2 mb-3">
						<span class="font-heading text-5xl font-bold text-neutral-700">{yearLifers}</span>
						<span class="text-lg text-gray-400">/ {YEARLY_GOAL}</span>
					</div>
					<div class="relative h-4 rounded-full bg-gray-200 overflow-hidden mb-1">
						<div class="absolute inset-y-0 left-0 rounded-full bg-[#f4793d]" style={`width: ${yearGoalPercent}%`}></div>
						<div class="absolute inset-y-0 w-0.5 bg-neutral-500/60" style={`left: ${yearElapsedPercent}%`} title="Today"></div>
					</div>
					<p class="text-xs text-gray-400 mb-8">{yearGoalPercent}% of goal &middot; {yearElapsedPercent}% of the year gone</p>
					<div class="border-t border-gray-100 pt-6">
						<p class="text-sm text-gray-500">
							<strong class="text-neutral-600 text-lg">{yearPhotographed}</strong> new species photographed in {currentYear}
							{' '}&middot;{' '}
							<a href={`/lifelist/${overview.years[0]}`} class="text-orange">see them all</a>
						</p>
					</div>
				</div>

				<div class="p-6 sm:p-10 bg-white flex-1">
					<h2 class="font-heading text-neutral-600 text-2xl mb-1">New Lifers by Year</h2>
					<p class="text-gray-500 text-sm mb-6">Species reported for the first time each year</p>
					<div class="relative">
						<svg viewBox={`0 0 ${chart.width} ${chart.height}`} class="w-full" id="lifers-chart" role="img" aria-label="Bar chart of new lifers per year">
							{yTicks.map((tick) => (
								<>
									<line x1={chart.left} x2={chart.width - chart.right} y1={yScale(tick)} y2={yScale(tick)} stroke="#f0f0f0" stroke-width="1" />
									<text x={chart.left - 8} y={yScale(tick) + 3} text-anchor="end" font-size="10" fill="#9ca3af">{tick}</text>
								</>
							))}
							<line
								x1={chart.left}
								x2={chart.width - chart.right}
								y1={yScale(YEARLY_GOAL)}
								y2={yScale(YEARLY_GOAL)}
								stroke="#737373"
								stroke-width="1.5"
								stroke-dasharray="5 4"
							/>
							<text
								x={chart.left + 6}
								y={yScale(YEARLY_GOAL) - 5}
								text-anchor="start"
								font-size="10"
								font-weight="bold"
								fill="#737373"
								stroke="#ffffff"
								stroke-width="3.5"
								paint-order="stroke"
							>
								Goal: {YEARLY_GOAL}
							</text>
							{chartYears.map(({ year, count }, i) => {
								const x = chart.left + i * slotW + slotW / 2;
								const y = yScale(count);
								const showLabel = count === maxYearCount || year === currentYear;
								return (
									<>
										<path
											d={`M ${x - barW / 2} ${chart.top + plotH} V ${y + 4} Q ${x - barW / 2} ${y} ${x - barW / 2 + 4} ${y} H ${x + barW / 2 - 4} Q ${x + barW / 2} ${y} ${x + barW / 2} ${y + 4} V ${chart.top + plotH} Z`}
											fill={brandOrange}
											class="chart-bar"
											data-year={year}
											data-count={count}
										/>
										{showLabel && (
											<text
												x={x}
												y={y - 6}
												text-anchor="middle"
												font-size="11"
												font-weight="bold"
												fill="#525252"
												stroke="#ffffff"
												stroke-width="3.5"
												paint-order="stroke"
											>
												{count}
											</text>
										)}
										<text x={x} y={chart.height - 8} text-anchor="middle" font-size="10" fill="#9ca3af">&rsquo;{year.slice(2)}</text>
										<rect
											x={chart.left + i * slotW}
											y={chart.top}
											width={slotW}
											height={plotH}
											fill="transparent"
											class="chart-hit"
											data-year={year}
											data-count={count}
										/>
									</>
								);
							})}
							<line x1={chart.left} x2={chart.width - chart.right} y1={chart.top + plotH} y2={chart.top + plotH} stroke="#d1d5db" stroke-width="1" />
						</svg>
						<div
							id="chart-tooltip"
							class="pointer-events-none absolute hidden -translate-x-1/2 -translate-y-full rounded bg-neutral-800 px-2.5 py-1.5 text-xs text-white whitespace-nowrap"
						></div>
					</div>
				</div>
			</div>

			<!-- Favorite families -->
			<div class="p-6 sm:p-12 bg-white mb-4">
				<h2 class="font-heading text-neutral-600 text-3xl mb-1">Family Quests</h2>
				<p class="text-gray-500 mb-8">
					The families I chase hardest — watching these grids fill up is half the fun.
					{' '}<a href="/families" class="text-orange">Browse all families</a>
				</p>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
					{favoriteFamilies.map(({ name, slug, count, total, recent }) => (
						<a href={`/families/${slug}`} class="group block border border-gray-100 hover:border-gray-200 overflow-hidden">
							<div class="grid grid-cols-3 gap-0.5">
								{recent.map((sp, i) => (
									<div class="relative">
										<img
											src={getEbirdImgUrl(sp.img, 480)}
											alt={sp.name}
											loading="lazy"
											class="w-full h-44 sm:h-56 object-cover"
										/>
										<div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 to-transparent pt-8 pb-1.5 px-2">
											<p class="text-[0.7rem] leading-tight text-white [text-shadow:0_1px_3px_rgba(0,0,0,0.9)]">
												{i === 0 && <span class="block uppercase text-[0.6rem] font-bold text-gray-300">Latest</span>}
												{sp.name}
											</p>
										</div>
									</div>
								))}
							</div>
							<div class="p-5">
								<div class="flex items-baseline mb-2">
									<h3 class="font-heading text-xl font-bold text-neutral-600 group-hover:text-orange">{name}</h3>
									<span class="ml-auto text-sm text-gray-500">
										<strong class="text-neutral-600 text-lg">{count}</strong> of {total} photographed
									</span>
								</div>
								<div class="relative h-3 rounded-full bg-gray-200 overflow-hidden">
									<div class="absolute inset-y-0 left-0 rounded-full bg-[#f4793d]" style={`width: ${(count / total) * 100}%`}></div>
								</div>
								<p class="text-xs text-gray-400 mt-1.5">{Math.round((count / total) * 100)}% complete</p>
							</div>
						</a>
					))}
				</div>
			</div>

			<!-- Countries -->
			<div class="p-6 sm:p-12 bg-white mb-4">
				<h2 class="font-heading text-neutral-600 text-3xl mb-1">Around the World</h2>
				<p class="text-gray-500 mb-8">Species reported in each of the {countries.length} countries I've birded</p>
				<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
					{countries.map(({ name, flag, count }) => (
						<div class="border border-gray-100 p-4">
							<div class="flex items-center gap-2 mb-2">
								<span class="text-xl leading-none">{flag}</span>
								<span class="text-sm text-gray-600 truncate" title={name}>{name}</span>
							</div>
							<div class="font-heading text-2xl font-bold text-neutral-700 mb-1.5">{count.toLocaleString()}</div>
							<div class="relative h-1.5 rounded-full bg-gray-100 overflow-hidden">
								<div class="absolute inset-y-0 left-0 rounded-full bg-[#f4793d]" style={`width: ${(count / maxCountryCount) * 100}%`}></div>
							</div>
						</div>
					))}
				</div>
			</div>

			<!-- Endemics -->
			{SHOW_ENDEMICS && (
			<div class="p-6 sm:p-12 bg-white mb-4">
				<h2 class="font-heading text-neutral-600 text-3xl mb-1">Endemics</h2>
				<p class="text-gray-500 mb-2">
					Some places are home to species found nowhere else on Earth — I'm working on photographing every one.
				</p>
				<div class="flex flex-wrap gap-x-5 gap-y-1 text-xs text-gray-400 mb-8">
					<span><span class="inline-block w-2.5 h-2.5 rounded-full bg-[#f4793d] align-[-1px]"></span> Photographed</span>
					<span><span class="inline-block w-2.5 h-2.5 rounded-full bg-neutral-400 align-[-1px]"></span> Seen, not photographed</span>
					<span><span class="inline-block w-2.5 h-2.5 rounded-full border border-gray-300 align-[-1px]"></span> Still searching</span>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					{endemicIslands.map(({ name, flag, species, photographed }) => (
						<div class="border border-gray-100 p-6">
							<div class="flex items-baseline mb-3">
								<h3 class="font-heading text-lg font-bold text-neutral-600">
									<span class="mr-1.5">{flag}</span>{name}
								</h3>
								<span class="ml-auto text-sm text-gray-500">
									<strong class="text-neutral-600">{photographed}</strong> of {species.length}
								</span>
							</div>
							<div class="relative h-2 rounded-full bg-gray-200 overflow-hidden mb-4">
								<div class="absolute inset-y-0 left-0 rounded-full bg-[#f4793d]" style={`width: ${(photographed / species.length) * 100}%`}></div>
							</div>
							<div class="flex flex-wrap gap-1.5">
								{species.map((sp) => (
									<a
										href={sp.photographed
											? `https://media.ebird.org/catalog?taxonCode=${sp.code}&sort=rating_rank_desc&mediaType=photo&userId=${ebirdUserId}`
											: `https://ebird.org/species/${sp.code}`
										}
										target="_blank"
										rel="noopener noreferrer"
										title={sp.notes}
										class={`text-xs px-2.5 py-1 rounded-full ${
											sp.photographed
												? 'bg-[#f4793d] text-white'
												: sp.seen
													? 'bg-neutral-400 text-white'
													: 'border border-gray-300 text-gray-400'
										}`}
									>
										{sp.name}{sp.isNear ? '*' : ''}
									</a>
								))}
							</div>
						</div>
					))}
				</div>
				<p class="text-xs text-gray-400 mt-6">* Near-endemic: also occurs in small numbers in nearby regions</p>
			</div>
			)}
		</div>

		<script>
			const tooltip = document.getElementById('chart-tooltip');
			const chart = document.getElementById('lifers-chart');
			document.querySelectorAll('.chart-hit').forEach((hit) => {
				hit.addEventListener('mouseenter', () => {
					if (!tooltip || !chart) return;
					const year = hit.getAttribute('data-year');
					const count = hit.getAttribute('data-count');
					tooltip.innerHTML = `<strong>${year}</strong> &middot; ${count} lifer${count === '1' ? '' : 's'}`;
					const chartRect = chart.getBoundingClientRect();
					const hitRect = hit.getBoundingClientRect();
					const bar = chart.querySelector(`.chart-bar[data-year="${year}"]`) as SVGGraphicsElement | null;
					const barRect = bar?.getBoundingClientRect();
					tooltip.style.left = `${hitRect.left + hitRect.width / 2 - chartRect.left}px`;
					tooltip.style.top = `${(barRect?.top ?? hitRect.top) - chartRect.top - 6}px`;
					tooltip.classList.remove('hidden');
					bar?.setAttribute('fill', '#c9571f');
				});
				hit.addEventListener('mouseleave', () => {
					tooltip?.classList.add('hidden');
					const year = hit.getAttribute('data-year');
					chart?.querySelector(`.chart-bar[data-year="${year}"]`)?.setAttribute('fill', '#e2632a');
				});
			});
		</script>
	</body>
</html>
