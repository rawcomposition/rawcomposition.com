---
import worldMap from '@/data/world-map.json';

type Props = {
	counts: { code: string; count: number }[];
	ebirdUserId?: string;
};

const { counts, ebirdUserId } = Astro.props;
const countryLink = (code: string) =>
	`https://media.ebird.org/catalog?regionCode=${code}&sort=rating_rank_desc&mediaType=photo&userId=${ebirdUserId}`;
const countByCode = new Map(counts.map(({ code, count }) => [code, count]));

const BUCKETS = [
	{ min: 400, color: '#a34413', label: '400+' },
	{ min: 200, color: '#cf5a1e', label: '200–399' },
	{ min: 100, color: '#f4793d', label: '100–199' },
	{ min: 50, color: '#f8a76c', label: '50–99' },
	{ min: 1, color: '#fbd3b4', label: '1–49' },
];
const fillFor = (count: number | undefined) =>
	count ? BUCKETS.find(({ min }) => count >= min)!.color : '#e4e5e9';

const markers = worldMap.markers.filter(({ code }) => countByCode.has(code));
---

<div class="relative" id="world-map">
	<svg viewBox={`0 0 ${worldMap.width} ${worldMap.height}`} class="w-full" role="img" aria-label="World map of countries I've birded, shaded by species count">
		{worldMap.countries.map(({ code, name, d }) => {
			const count = countByCode.get(code);
			const path = (
				<path
					d={d}
					fill={fillFor(count)}
					stroke="#ffffff"
					stroke-width="0.6"
					class={count ? 'map-country cursor-pointer' : undefined}
					data-name={name}
					data-count={count}
				/>
			);
			return count ? <a href={countryLink(code)} target="_blank" rel="noopener noreferrer">{path}</a> : path;
		})}
		{markers.map(({ code, name, x, y }) => (
			<a href={countryLink(code)} target="_blank" rel="noopener noreferrer">
				<circle
					cx={x}
					cy={y}
					r="5"
					fill={fillFor(countByCode.get(code))}
					stroke="#ffffff"
					stroke-width="1.5"
					class="map-country cursor-pointer"
					data-name={name}
					data-count={countByCode.get(code)}
				/>
			</a>
		))}
	</svg>
	<div
		id="map-tooltip"
		class="pointer-events-none absolute hidden -translate-x-1/2 -translate-y-full rounded bg-neutral-800 px-2.5 py-1.5 text-xs text-white whitespace-nowrap z-10"
	></div>
	<div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-2 text-xs text-gray-500">
		<span class="font-bold text-gray-400 uppercase text-[0.65rem] tracking-wide">Species reported</span>
		{[...BUCKETS].reverse().map(({ color, label }) => (
			<span class="inline-flex items-center gap-1.5">
				<span class="inline-block w-3 h-3 rounded-sm" style={`background: ${color}`}></span>
				{label}
			</span>
		))}
	</div>
</div>

<script>
	const map = document.getElementById('world-map');
	const tooltip = document.getElementById('map-tooltip');
	map?.querySelectorAll('.map-country').forEach((el) => {
		el.addEventListener('mousemove', (event) => {
			if (!tooltip || !map) return;
			const name = el.getAttribute('data-name');
			const count = el.getAttribute('data-count');
			tooltip.innerHTML = `<strong>${name}</strong> &middot; ${count} species`;
			const mapRect = map.getBoundingClientRect();
			const e = event as MouseEvent;
			tooltip.style.left = `${e.clientX - mapRect.left}px`;
			tooltip.style.top = `${e.clientY - mapRect.top - 12}px`;
			tooltip.classList.remove('hidden');
		});
		el.addEventListener('mouseleave', () => tooltip?.classList.add('hidden'));
	});
</script>
